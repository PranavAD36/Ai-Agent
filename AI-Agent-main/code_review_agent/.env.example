# ============================================================
#  Autonomous Code Review & Debugging Agent — Environment Vars
# ============================================================

# --- LLM API Keys (at least one is required) ----------------

# Google Gemini API keys
GEMINI_API_KEY_1=your_gemini_api_key_1_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here
GOOGLE_API_KEY=your_gemini_api_key_1_here # Backwards compatibility alias

# Groq API keys
GROQ_API_KEY_1=your_groq_api_key_1_here
GROQ_API_KEY_2=your_groq_api_key_2_here
GROQ_API_KEY=your_groq_api_key_1_here # Backwards compatibility alias

# OpenAI API key (optional — for GPT-4 fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API key (optional — for Claude fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Sandbox -------------------------------------------------

# E2B sandbox API key (required for sandboxed test execution)
E2B_API_KEY=your_e2b_api_key_here

# --- GitHub --------------------------------------------------

# GitHub Personal Access Token (optional — needed for private repos)
GITHUB_TOKEN=your_github_token_here

# --- Model Configuration ------------------------------------

# Default LLM provider: "gemini" | "openai" | "anthropic"
LLM_PROVIDER=gemini

# Default model name (e.g., gemini-2.0-flash, gpt-4, claude-3-5-sonnet)
LLM_MODEL=gemini-2.0-flash
